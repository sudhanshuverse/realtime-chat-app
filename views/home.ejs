<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Nexus — Real-Time Chat</title>
  <link rel="stylesheet" href="/css/home.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
</head>
<body>

  <div class="mesh"></div>
  <div class="grid-lines"></div>

  <!-- NAV -->
  <nav id="nav">
    <div class="nav-logo">
      <div class="logo-icon">
        <svg fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <span class="logo-name brand">Nexus</span>
    </div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="#stats">Stats</a>
    </div>
    <div class="nav-right">
      <a href="/login" class="nav-signin">Sign in</a>
      <a href="/login" class="nav-cta">Get started free</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Now open source · v1.0
    </div>
    <h1>Chat without<br/><span class="gradient-text">limits.</span></h1>
    <p class="hero-sub">
      Nexus is a real-time messaging platform built for teams and communities — instant delivery, persistent history, and a UI that doesn't get in your way.
    </p>
    <div class="hero-actions">
      <a href="/login" class="btn-hero">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        Start chatting free
      </a>
      <a href="#features" class="btn-ghost">
        Explore features
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- PREVIEW WINDOW -->
  <div class="preview-container">
    <div class="preview-window">
      <div class="window-bar">
        <div class="window-dot" style="background:#ff5f57"></div>
        <div class="window-dot" style="background:#febc2e"></div>
        <div class="window-dot" style="background:#28c840"></div>
        <span class="window-title">nexus.app — general</span>
      </div>
      <div class="window-body">
        <div class="w-sidebar">
          <div class="w-room-label">Rooms</div>
          <div class="w-room active"># general</div>
          <div class="w-room"># design</div>
          <div class="w-room"># backend <span class="w-room-badge">3</span></div>
          <div class="w-room"># random</div>
          <div class="w-spacer"></div>
          <div class="w-online">
            <div class="w-online-label">Online</div>
            <div class="w-user"><div class="w-dot"></div><span class="w-username">alex</span></div>
            <div class="w-user"><div class="w-dot"></div><span class="w-username">priya</span></div>
            <div class="w-user"><div class="w-dot"></div><span class="w-username">sam</span></div>
          </div>
        </div>
        <div class="w-chat">
          <div class="w-chat-header"><span>#</span> general</div>
          <div class="w-messages">
            <div class="w-msg float-1">
              <div class="w-avatar" style="background:linear-gradient(135deg,#4f46e5,#7c3aed)">A</div>
              <div class="w-msg-body">
                <div class="w-sender">alex</div>
                <div class="w-bubble">Hey team! Just deployed the new feature 🚀</div>
              </div>
            </div>
            <div class="w-msg float-2">
              <div class="w-avatar" style="background:linear-gradient(135deg,#059669,#047857)">P</div>
              <div class="w-msg-body">
                <div class="w-sender">priya</div>
                <div class="w-bubble">Looks amazing! Tested it already ✨</div>
              </div>
            </div>
            <div class="w-msg own float-3">
              <div class="w-msg-body">
                <div class="w-bubble">Thanks! Took all night but worth it 😅</div>
                <div class="w-meta">
                  <span class="w-time">11:42</span>
                  <span class="w-tick">✔✔</span>
                </div>
              </div>
            </div>
            <div class="w-msg float-4">
              <div class="w-avatar" style="background:linear-gradient(135deg,#d97706,#b45309)">S</div>
              <div class="w-msg-body">
                <div class="w-sender">sam</div>
                <div class="w-bubble">🔥🔥 Incredible work!</div>
              </div>
            </div>
          </div>
          <div class="w-input">
            <div class="w-input-box">Type a message...</div>
            <div class="w-send">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <section class="section" id="stats">
    <div class="section-inner-md reveal">
      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-num gradient-text">∞</div>
          <div class="stat-label">Rooms available</div>
        </div>
        <div class="stat-item">
          <div class="stat-num gradient-text">&lt;50ms</div>
          <div class="stat-label">Message delivery</div>
        </div>
        <div class="stat-item">
          <div class="stat-num gradient-text">100%</div>
          <div class="stat-label">Open source</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section" id="features">
    <div class="section-inner">
      <div class="reveal">
        <span class="section-tag">Everything you need</span>
        <h2 class="section-title">Built for real<br/>conversations</h2>
        <p class="section-sub">Every feature you'd expect from a modern messaging app — and then some.</p>
      </div>
      <div class="features-grid reveal">
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(99,102,241,0.15)">⚡</div>
          <div class="feature-title">Instant Delivery</div>
          <div class="feature-desc">Messages appear in under 50ms via WebSockets. No polling, no delays — pure real-time communication.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(34,197,94,0.12)">✔✔</div>
          <div class="feature-title">Message Status</div>
          <div class="feature-desc">Know exactly when your message was sent, delivered, and seen with WhatsApp-style read receipts.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(234,179,8,0.12)">💬</div>
          <div class="feature-title">Threaded Replies</div>
          <div class="feature-desc">Reply to any specific message to keep conversations organized and easy to follow.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(239,68,68,0.12)">😂</div>
          <div class="feature-title">Emoji Reactions</div>
          <div class="feature-desc">React to messages with 6 emoji options. Toggle your reaction or let others pile on.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(6,182,212,0.12)">✍️</div>
          <div class="feature-title">Typing Indicators</div>
          <div class="feature-desc">See who's composing a message in real-time, so conversations feel truly live.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(139,92,246,0.15)">🏠</div>
          <div class="feature-title">Unlimited Rooms</div>
          <div class="feature-desc">Create any room instantly by typing a name. Invite your team, friends, or anyone you like.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(16,185,129,0.12)">🟢</div>
          <div class="feature-title">Online Presence</div>
          <div class="feature-desc">See who's currently active with live green indicators. Know who's available before you message.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(245,158,11,0.12)">📜</div>
          <div class="feature-title">Chat History</div>
          <div class="feature-desc">All messages persist in MongoDB. Scroll back to catch up on everything you missed.</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:rgba(99,102,241,0.12)">🔐</div>
          <div class="feature-title">Secure Auth</div>
          <div class="feature-desc">JWT tokens + bcrypt hashing keep your account protected. Authentication built right in.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section section-alt" id="how">
    <div class="section-inner">
      <div class="section-header-centered reveal">
        <span class="section-tag">Simple by design</span>
        <h2 class="section-title">Up in three steps</h2>
        <p class="section-sub centered">No complicated setup. No invites required. Just type a room name and go.</p>
      </div>
      <div class="steps reveal">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-title">Create an account</div>
          <div class="step-desc">Pick a username and password. That's it — you're in. No email, no verification.</div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-title">Join a room</div>
          <div class="step-desc">Type any room name to join instantly. Share the name with others to chat together.</div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-title">Start chatting</div>
          <div class="step-desc">Send messages, react, reply, and see who's online — all in real time.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-card reveal">
      <h2>Ready to connect?</h2>
      <p>Join rooms instantly. No setup, no credit card required.</p>
      <div class="cta-actions">
        <a href="/login" class="btn-hero">
          <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Open the app
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">
      <div class="footer-logo-icon">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <span class="footer-brand-name">Nexus</span>
    </div>
    <div class="footer-links">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="/login">Sign in</a>
    </div>
    <span class="footer-credit">Built with Socket.io · Node.js · MongoDB</span>
  </footer>

  <script>
    window.addEventListener('scroll', () => {
      document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 40);
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) setTimeout(() => entry.target.classList.add('visible'), i * 80);
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    const cardObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        document.querySelectorAll('.feature-card').forEach((card, i) => {
          setTimeout(() => { card.style.opacity = '1'; card.style.transform = 'translateY(0)'; }, i * 60);
        });
      }
    }, { threshold: 0.1 });
    document.querySelectorAll('.feature-card').forEach(c => {
      c.style.opacity = '0'; c.style.transform = 'translateY(20px)';
      c.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    const grid = document.querySelector('.features-grid');
    if (grid) cardObserver.observe(grid);
  </script>

</body>
</html>
